<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Banner image at top of about screen -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/inspiration_banner"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:layout_marginBottom="16dp" />

    <!-- App name heading -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ARF Companion"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp" />

    <!-- Version string -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp" />

    <!-- Short app description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="4dp"
        android:text="Companion app for ARF Firmware\nCrypto offloader/settings manager for the ARF Firmware."
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurface" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:layout_marginBottom="16dp" />

    <!-- GitHub links for firmware and companion app -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="4dp"
        android:text="Firmware:\nhttps://github.com/D4C1-Labs/Flipper-ARF\n\nCompanion App:\nhttps://github.com/D4C1-Labs/arf-android-companion"
        android:textSize="13sp"
        android:textColor="?attr/colorPrimary"
        android:autoLink="web" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:layout_marginBottom="16dp" />

    <!-- Credits footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Built by luhf for ARF Firmware\nARF Firmware by D4rk$1d3, luhf, 47LeCoste, DACI\n[and many others]"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp" />

</LinearLayout>
</ScrollView>
