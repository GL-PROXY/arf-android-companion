<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground">

    <!-- File/folder type icon (set in code based on entry type) -->
    <ImageView
        android:id="@+id/img_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@android:drawable/ic_menu_save"
        app:tint="?attr/colorOnSurfaceVariant" />

    <!-- File name and size info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <!-- Entry name, truncated in middle if too long -->
        <TextView
            android:id="@+id/txt_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="filename.txt"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:singleLine="true"
            android:ellipsize="middle" />

        <!-- File size, hidden for directories -->
        <TextView
            android:id="@+id/txt_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1.2 KB"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Overflow menu: download, delete, etc. -->
    <ImageButton
        android:id="@+id/btn_more"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_more"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="More options"
        app:tint="?attr/colorOnSurfaceVariant" />

</LinearLayout>
