<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Preset name input field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preset Name"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/edit_preset_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. FM95"
            android:textSize="14sp"
            android:inputType="text"
            android:paddingBottom="12dp" />

        <!-- Paste full hex config string from clipboard to auto-fill fields -->
        <Button
            android:id="@+id/btn_paste_hex"
            style="@style/TextButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Paste hex data from clipboard"
            android:textSize="12sp"

            android:layout_marginBottom="8dp"
 />

        <!-- Section label: CC1101 register address/value pairs -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorPrimary"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Column headers for the register pair rows below -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />

            <View android:layout_width="16dp" android:layout_height="0dp" />

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="Value"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />
        </LinearLayout>

        <!-- Dynamically inflated item_register_pair rows added by SubGhzSettingsFragment -->
        <LinearLayout
            android:id="@+id/register_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btn_add_register"
            style="@style/TextButton"
            android:text="+ Add Register"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:textSize="12sp"

 />

        <!-- Divider between registers and PA table sections -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:layout_marginVertical="12dp"
            android:alpha="0.3" />

        <!-- Section label: CC1101 PA power table -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorPrimary"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:paddingBottom="8dp" />

        <!-- PA table bytes 0-3 (first row of 8-byte table) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <EditText
                android:id="@+id/pa_0"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/pa_1"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/pa_2"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/pa_3"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions" />
        </LinearLayout>

        <!-- PA table bytes 4-7 (second row of 8-byte table) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/pa_4"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/pa_5"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/pa_6"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/pa_7"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:hint="00"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLength="2"
                android:inputType="textCapCharacters|textNoSuggestions" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
