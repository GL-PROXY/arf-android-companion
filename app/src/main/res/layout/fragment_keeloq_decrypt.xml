<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KeeLoq BF Parameters"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="2dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Magic Serial Type 1/2/3 brute force"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="12dp" />
            <EditText
                android:id="@+id/kl_fix_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fix (e.g. 91234567)"
                android:inputType="textCapCharacters"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOutline"
                android:backgroundTint="?attr/colorPrimary"
                android:layout_marginBottom="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <EditText
                    android:id="@+id/kl_hop1_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Hop1 (msg 1)"
                    android:inputType="textCapCharacters"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOutline"
                    android:backgroundTint="?attr/colorPrimary"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/kl_hop2_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Hop2 (msg 2)"
                    android:inputType="textCapCharacters"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOutline"
                    android:backgroundTint="?attr/colorPrimary" />
            </LinearLayout>
            <Spinner
                android:id="@+id/kl_type_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/kl_run_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Run BF"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/kl_bench_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Benchmark"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/kl_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />
            <ProgressBar
                android:id="@+id/kl_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:progressTint="?attr/colorPrimary"
                android:progressBackgroundTint="?attr/colorOutline"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/kl_progress_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace" />
            <TextView
                android:id="@+id/kl_speed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/kl_result_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:textColor="?attr/colorPrimary"
                android:textIsSelectable="true" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
</ScrollView>
