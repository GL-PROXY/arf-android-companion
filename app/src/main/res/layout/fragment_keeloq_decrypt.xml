<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <!-- Card title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KeeLoq BF Parameters"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="2dp" />
            <!-- Card subtitle describing brute force method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Magic Serial Type 1/2/3 brute force"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="12dp" />
            <!-- Fix word input (8 hex chars) -->
            <EditText
                android:id="@+id/kl_fix_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fix (e.g. 91234567)"
                android:inputType="textCapCharacters"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOutline"
                android:backgroundTint="?attr/colorPrimary"
                android:layout_marginBottom="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <!-- First captured hop value -->
                <EditText
                    android:id="@+id/kl_hop1_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Hop1 (msg 1)"
                    android:inputType="textCapCharacters"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOutline"
                    android:backgroundTint="?attr/colorPrimary"
                    android:layout_marginEnd="8dp" />
                <!-- Second captured hop value -->
                <EditText
                    android:id="@+id/kl_hop2_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Hop2 (msg 2)"
                    android:inputType="textCapCharacters"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOutline"
                    android:backgroundTint="?attr/colorPrimary" />
            </LinearLayout>
            <!-- KeeLoq serial type selector (Type 1/2/3) -->
            <Spinner
                android:id="@+id/kl_type_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cores:"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginEnd="8dp" />
                <!-- Number of CPU cores to use for brute force -->
                <Spinner
                    android:id="@+id/kl_core_spinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Start the brute force attack -->
                <Button
                    android:id="@+id/kl_run_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Run BF"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />
                <!-- Run a speed benchmark without searching -->
                <Button
                    android:id="@+id/kl_bench_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Benchmark"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <!-- Status card title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />
            <!-- Current operation status e.g. "Running", "Found!" -->
            <TextView
                android:id="@+id/kl_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />
            <!-- Brute force progress 0-100% -->
            <ProgressBar
                android:id="@+id/kl_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:progressTint="?attr/colorPrimary"
                android:progressBackgroundTint="?attr/colorOutline"
                android:layout_marginBottom="4dp" />
            <!-- Percentage and keys-tried counter -->
            <TextView
                android:id="@+id/kl_progress_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace" />
            <!-- Keys-per-second throughput -->
            <TextView
                android:id="@+id/kl_speed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />
            <!-- Found key result, selectable for copy -->
            <TextView
                android:id="@+id/kl_result_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:textColor="?attr/colorPrimary"
                android:textIsSelectable="true" />
            <!-- Note about CPU throttling affecting speed -->
            <TextView
                android:id="@+id/kl_disclaimer_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Speed varies due to CPU thermal throttling. An initial burst followed by a slowdown is normal."
                android:textSize="11sp"
                android:textColor="?attr/colorOutline"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
</ScrollView>
