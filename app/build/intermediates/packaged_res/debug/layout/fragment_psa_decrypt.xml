<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_surface">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Manual input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BF Parameters (hex):"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/w0_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="w0 (e.g. A1B2C3D4)"
            android:inputType="textCapCharacters"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/dark_divider"
            android:backgroundTint="@color/accent"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/w1_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="w1 (e.g. E5F6A7B8)"
            android:inputType="textCapCharacters"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/dark_divider"
            android:backgroundTint="@color/accent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/run_bf1_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Run BF1"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/run_bf2_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Run BF2"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/run_both_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Run Both"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/test_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Benchmark"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <!-- Status + Progress -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp" />

    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/accent"
        android:progressBackgroundTint="@color/dark_divider"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/progress_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/speed_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/result_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textColor="@color/green"
        android:textIsSelectable="true" />

</LinearLayout>
</ScrollView>
