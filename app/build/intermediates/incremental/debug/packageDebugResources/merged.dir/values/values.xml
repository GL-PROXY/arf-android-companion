<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent">#FFFF6F00</color>
    <color name="black">#FF000000</color>
    <color name="dark_card">#FF1E1E1E</color>
    <color name="dark_divider">#FF333333</color>
    <color name="dark_surface">#FF121212</color>
    <color name="green">#FF4CAF50</color>
    <color name="log_bg">#FF0A0A0A</color>
    <color name="log_text">#FFAAAAAA</color>
    <color name="text_primary">#FFEEEEEE</color>
    <color name="text_secondary">#FFB0B0B0</color>
    <string name="app_name">Inspiration Companion</string>
    <string name="nav_close">Close navigation</string>
    <string name="nav_open">Open navigation</string>
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:windowBackground">@color/dark_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:colorEdgeEffect">@color/accent</item>

        
        <item name="materialButtonStyle">@style/DarkButton</item>
    </style>
    <style name="DarkButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/black</item>
    </style>
</resources>